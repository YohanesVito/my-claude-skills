# ── App identity ─────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=

# ── WalletConnect ────────────────────────────────────────────────
# Get one at https://cloud.walletconnect.com (free)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# ── Default chain ────────────────────────────────────────────────
# 84532=Base 421614=Arbitrum 11155420=OP 5003=Mantle 10143=Monad
NEXT_PUBLIC_DEFAULT_CHAIN_ID=84532

# ── Optional RPC overrides (custom chains) ───────────────────────
NEXT_PUBLIC_MANTLE_SEPOLIA_RPC_URL=
NEXT_PUBLIC_MONAD_TESTNET_RPC_URL=

# ── Deployed contract addresses (fill after deploy) ──────────────
NEXT_PUBLIC_CONTRACT_BASE_SEPOLIA=
NEXT_PUBLIC_CONTRACT_ARBITRUM_SEPOLIA=
NEXT_PUBLIC_CONTRACT_OPTIMISM_SEPOLIA=
NEXT_PUBLIC_CONTRACT_MANTLE_SEPOLIA=
NEXT_PUBLIC_CONTRACT_MONAD_TESTNET=
